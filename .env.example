# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# =============================================================================
# ADMIN API (for password reset)
# =============================================================================
# Generate with: openssl rand -base64 32
# Used for: /api/admin/* endpoints
ADMIN_SECRET="generate-with-openssl-rand-base64-32"

# =============================================================================
# DEBUG ROUTE CONTROL (RECOMMENDED: false in production/preview)
# =============================================================================
# In production, debug routes are available only when BOTH are true:
# 1) ENABLE_DEBUG_ROUTES=true
# 2) Authorization: Bearer <ADMIN_SECRET>
ENABLE_DEBUG_ROUTES="false"

# =============================================================================
# CRON JOBS (Vercel Cron)
# =============================================================================
CRON_SECRET="generate-with: openssl rand -base64 32"

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# =============================================================================
# EXTERNAL APIS (Optional)
# =============================================================================
# Finnhub for stock news (free tier: 60 req/min)
FINNHUB_API_KEY=""

# DNSE API for Vietnamese stocks
DNSE_API_KEY=""
DNSE_API_SECRET=""

# CoinGecko for cryptocurrency prices (free tier available)
COINGECKO_API_KEY=""

# Gold price API
GOLD_API_KEY=""

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# =============================================================================
# VERCEL (Auto-set by Vercel)
# =============================================================================
# NODE_ENV="production"
# VERCEL_URL="your-app.vercel.app"
# VERCEL_REGION="sin1"

# =============================================================================
# TESTING (for local development)
# =============================================================================
TEST_DATABASE_URL="postgresql://test:test@localhost:5432/portfolio_test"
