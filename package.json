{
    "name": "portfolio-tracker",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --ext .ts,.tsx",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "test": "vitest run --config vitest.config.mjs",
        "test:watch": "vitest --config vitest.config.mjs",
        "typecheck": "tsc --noEmit",
        "check": "npm run typecheck && npm run lint && npm run test",
        "load:health": "k6 run k6/health.js",
        "load:quotes": "k6 run k6/quotes.js",
        "load:batch": "k6 run k6/quotes-batch.js",
        "load:refresh": "k6 run k6/quotes-refresh.js",
        "load:all": "k6 run k6/comprehensive.js",
        "load:smoke": "k6 run --env SCENARIO=smoke k6/health.js",
        "load:stress": "k6 run --env SCENARIO=stress k6/comprehensive.js"
    },
    "dependencies": {
        "@neondatabase/serverless": "^0.9.3",
        "@sentry/nextjs": "^10.47.0",
        "clsx": "^2.1.1",
        "decimal.js": "^10.6.0",
        "drizzle-orm": "^0.30.10",
        "lucide-react": "^0.378.0",
        "next": "^16.2.2",
        "papaparse": "^5.4.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "recharts": "^2.12.7",
        "sonner": "^1.4.41",
        "tailwind-merge": "^2.3.0",
        "xlsx": "^0.18.5",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@types/node": "^20.12.11",
        "@types/papaparse": "^5.3.14",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.0",
        "autoprefixer": "^10.4.27",
        "dotenv": "^16.4.5",
        "drizzle-kit": "^0.21.1",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.2",
        "globals": "^17.4.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.19",
        "tsx": "^4.10.1",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.2"
    }
}
